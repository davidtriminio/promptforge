PORT=5000
NODE_ENV=development
TRUST_PROXY=false

MONGO_URI=your_mongodb_connection_string

CORS_ORIGINS=http://localhost:5173

COOKIE_SECRET=replace_with_cookie_secret
ACCESS_COOKIE_NAME=promptforge_access
REFRESH_COOKIE_NAME=promptforge_refresh
CSRF_COOKIE_NAME=promptforge_csrf
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_WINDOW_MINUTES=15

JSON_LIMIT=100kb
URL_ENCODED_LIMIT=100kb

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000